{
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": true,
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "react": {
        "runtime": "automatic"
      }
    },
    "target": "es2020",
    "loose": true
  },
  "module": {
    "type": "es6"
  },
  "minify": false,
  "sourceMaps": true,
  "env": {
    "test": {
      "module": {
        "type": "commonjs"
      }
    }
  }
}